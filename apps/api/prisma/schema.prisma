generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// CORE: Instituciones y Contratos
// =========================

model Institution {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  type              InstitutionType
  taxId             String?  @map("tax_id")
  country           String   @default("DO")
  status            EntityStatus @default(ACTIVE)
  
  // Reglas de negocio
  maxDiscountAuto   Decimal? @map("max_discount_auto") @db.Decimal(5, 2)
  maxDiscountManual Decimal? @map("max_discount_manual") @db.Decimal(5, 2)
  minInstallments   Int?     @map("min_installments")
  maxInstallments   Int?     @map("max_installments")
  autoApprovalLimit Decimal? @map("auto_approval_limit") @db.Decimal(15, 2)
  
  // Relaciones
  contracts         InstitutionContract[]
  portfolios        Portfolio[]
  users             User[]
  cases             Case[]
  agreements        Agreement[]
  payments          Payment[]
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  
  @@map("institutions")
}

model InstitutionContract {
  id              String   @id @default(uuid()) @db.Uuid
  institutionId   String   @map("institution_id") @db.Uuid
  institution     Institution @relation(fields: [institutionId], references: [id])
  
  contractType    String   @map("contract_type")
  discountRules   Json?    @map("discount_rules")
  commissionRules Json?    @map("commission_rules")
  sla             String?
  requiredDocs    String[] @map("required_documents")
  startDate       DateTime @map("start_date")
  endDate         DateTime? @map("end_date")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@map("institution_contracts")
}

// =========================
// CORE: Carteras
// =========================

model Portfolio {
  id              String   @id @default(uuid()) @db.Uuid
  institutionId   String   @map("institution_id") @db.Uuid
  institution     Institution @relation(fields: [institutionId], references: [id])
  
  name            String
  type            PortfolioType
  totalAmount     Decimal  @map("total_amount") @db.Decimal(15, 2)
  currency        String   @default("DOP")
  fileSource      String?  @map("file_source")
  uploadDate      DateTime @default(now()) @map("upload_date")
  status          PortfolioStatus @default(ACTIVE)
  
  // Relaciones
  rules           PortfolioRule?
  cases           Case[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  
  @@map("portfolios")
}

model PortfolioRule {
  id              String   @id @default(uuid()) @db.Uuid
  portfolioId     String   @unique @map("portfolio_id") @db.Uuid
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id])
  
  discountMax     Decimal? @map("discount_max") @db.Decimal(5, 2)
  minInstallments Int?     @map("min_installments")
  maxInstallments Int?     @map("max_installments")
  autoApprovalLimit Decimal? @map("auto_approval_limit") @db.Decimal(15, 2)
  channelsAllowed String[] @map("channels_allowed")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@map("portfolio_rules")
}

// =========================
// CORE: Deudores y Expedientes
// =========================

model Debtor {
  id          String   @id @default(uuid()) @db.Uuid
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  idNumber    String   @map("id_number") // Cedula
  idType      String   @default("cedula") @map("id_type")
  
  // Relaciones
  cases       Case[]
  contacts    Contact[]
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  
  @@map("debtors")
}

model Case {
  id                String   @id @default(uuid()) @db.Uuid
  institutionId     String   @map("institution_id") @db.Uuid
  institution       Institution @relation(fields: [institutionId], references: [id])
  portfolioId       String   @map("portfolio_id") @db.Uuid
  portfolio         Portfolio @relation(fields: [portfolioId], references: [id])
  debtorId          String   @map("debtor_id") @db.Uuid
  debtor            Debtor   @relation(fields: [debtorId], references: [id])
  
  caseNumber        String   @map("case_number")
  status            CaseStatus @default(ACTIVE)
  totalBalance      Decimal  @map("total_balance") @db.Decimal(15, 2)
  assignedDate      DateTime @default(now()) @map("assigned_date")
  nextAction        String?  @map("next_action")
  nextActionDate    DateTime? @map("next_action_date")
  
  // Scores
  scoreDocumental     Int?   @map("score_documental")
  scoreRecoverability Int?   @map("score_recoverability")
  scoreContactability Int?   @map("score_contactability")
  scoreRisk           Int?   @map("score_risk")
  
  // Relaciones
  products          CaseProduct[]
  documents         Document[]
  communications    Communication[]
  agreements        Agreement[]
  payments          Payment[]
  disputes          Dispute[]
  dataPassports     DataPassport[]
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  
  @@map("cases")
}

model CaseProduct {
  id              String   @id @default(uuid()) @db.Uuid
  caseId          String   @map("case_id") @db.Uuid
  case            Case     @relation(fields: [caseId], references: [id])
  
  productType     String   @map("product_type")
  originalAmount  Decimal  @map("original_amount") @db.Decimal(15, 2)
  currentBalance  Decimal  @map("current_balance") @db.Decimal(15, 2)
  interestRate    Decimal? @map("interest_rate") @db.Decimal(5, 2)
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@map("case_products")
}

// =========================
// DOCUMENTOS
// =========================

model Document {
  id          String   @id @default(uuid()) @db.Uuid
  caseId      String   @map("case_id") @db.Uuid
  case        Case     @relation(fields: [caseId], references: [id])
  uploadedBy  String   @map("uploaded_by") @db.Uuid
  
  filename    String
  filePath    String   @map("file_path")
  fileHash    String   @map("file_hash") // SHA-256
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  
  @@map("documents")
}

// =========================
// CONTACTOS Y CONSENTIMIENTOS
// =========================

model Contact {
  id              String   @id @default(uuid()) @db.Uuid
  debtorId        String   @map("debtor_id") @db.Uuid
  debtor          Debtor   @relation(fields: [debtorId], references: [id])
  
  channel         ContactChannel
  value           String
  isPrimary       Boolean  @default(false) @map("is_primary")
  optIn           Boolean  @default(false) @map("opt_in")
  optInDate       DateTime? @map("opt_in_date")
  
  // Data Passport linkage
  dataPassportId  String?  @map("data_passport_id") @db.Uuid
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  
  @@map("contacts")
}

model Consent {
  id            String   @id @default(uuid()) @db.Uuid
  debtorId      String   @map("debtor_id") @db.Uuid
  type          ConsentType
  granted       Boolean
  grantedAt     DateTime? @map("granted_at")
  revokedAt     DateTime? @map("revoked_at")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("consents")
}

// =========================
// COMUNICACIONES
// =========================

model Communication {
  id              String   @id @default(uuid()) @db.Uuid
  caseId          String   @map("case_id") @db.Uuid
  case            Case     @relation(fields: [caseId], references: [id])
  contactId       String?  @map("contact_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  
  channel         CommChannel
  direction       CommDirection @default(OUTBOUND)
  contentSummary  String?  @map("content_summary")
  status          CommStatus @default(PENDING)
  
  // Legal Firewall
  blocked         Boolean  @default(false)
  blockReason     String?  @map("block_reason")
  
  createdAt       DateTime @default(now()) @map("created_at")
  ipAddress       String?  @map("ip_address")
  
  @@map("communications")
}

// =========================
// ACUERDOS Y PAGOS
// =========================

model Agreement {
  id                String   @id @default(uuid()) @db.Uuid
  caseId            String   @map("case_id") @db.Uuid
  case              Case     @relation(fields: [caseId], references: [id])
  institutionId     String   @map("institution_id") @db.Uuid
  institution       Institution @relation(fields: [institutionId], references: [id])
  
  type              AgreementType
  amount            Decimal  @db.Decimal(15, 2)
  discountPercentage Decimal? @map("discount_percentage") @db.Decimal(5, 2)
  installments      Int?
  status            AgreementStatus @default(DRAFT)
  
  approvedBy        String?  @map("approved_by") @db.Uuid
  approvedAt        DateTime? @map("approved_at")
  createdBy         String   @map("created_by") @db.Uuid
  
  // Relaciones
  promises          Promise[]
  payments          Payment[]
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  
  @@map("agreements")
}

model Promise {
  id            String   @id @default(uuid()) @db.Uuid
  agreementId   String   @map("agreement_id") @db.Uuid
  agreement     Agreement @relation(fields: [agreementId], references: [id])
  
  promisedDate  DateTime @map("promised_date")
  promisedAmount Decimal  @map("promised_amount") @db.Decimal(15, 2)
  status        PromiseStatus @default(PENDING)
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@map("promises")
}

model Payment {
  id              String   @id @default(uuid()) @db.Uuid
  caseId          String   @map("case_id") @db.Uuid
  case            Case     @relation(fields: [caseId], references: [id])
  agreementId     String?  @map("agreement_id") @db.Uuid
  agreement       Agreement? @relation(fields: [agreementId], references: [id])
  institutionId   String   @map("institution_id") @db.Uuid
  institution     Institution @relation(fields: [institutionId], references: [id])
  
  amount          Decimal  @db.Decimal(15, 2)
  method          PaymentMethod
  reference       String?
  receiptPath     String?  @map("receipt_path")
  status          PaymentStatus @default(PENDING)
  
  reconciledAt    DateTime? @map("reconciled_at")
  reconciledBy    String?  @map("reconciled_by") @db.Uuid
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@map("payments")
}

// =========================
// DISPUTAS
// =========================

model Dispute {
  id              String   @id @default(uuid()) @db.Uuid
  caseId          String   @map("case_id") @db.Uuid
  case            Case     @relation(fields: [caseId], references: [id])
  
  reason          String
  description     String?
  status          DisputeStatus @default(OPEN)
  
  openedBy        String   @map("opened_by") @db.Uuid
  openedAt        DateTime @default(now()) @map("opened_at")
  resolvedBy      String?  @map("resolved_by") @db.Uuid
  resolvedAt      DateTime? @map("resolved_at")
  resolution      String?
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@map("disputes")
}

// =========================
// USUARIOS Y ROLES (complemento a Keycloak)
// =========================

model User {
  id              String   @id @default(uuid()) @db.Uuid
  keycloakId      String?  @unique @map("keycloak_id")
  institutionId   String?  @map("institution_id") @db.Uuid
  institution     Institution? @relation(fields: [institutionId], references: [id])
  
  email           String   @unique
  name            String
  role            UserRole
  status          EntityStatus @default(ACTIVE)
  mfaEnabled      Boolean  @default(false) @map("mfa_enabled")
  
  lastLoginAt     DateTime? @map("last_login_at")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  
  @@map("users")
}

// =========================
// AUDITORIA (INMUTABLE)
// =========================

model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  institutionId   String?  @map("institution_id") @db.Uuid
  
  action          AuditAction
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id") @db.Uuid
  changesJson     Json?    @map("changes_json")
  
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@map("audit_logs")
}

// =========================
// DATA PASSPORT (Legal Firewall)
// =========================

model DataPassport {
  id              String   @id @default(uuid()) @db.Uuid
  caseId          String   @map("case_id") @db.Uuid
  case            Case     @relation(fields: [caseId], references: [id])
  
  entityType      String   @map("entity_type") // debtor, contact, document, etc.
  entityId        String   @map("entity_id") @db.Uuid
  fieldName       String   @map("field_name")
  fieldValueHash  String?  @map("field_value_hash")
  
  // Provenance
  sourceType      String   @map("source_type") // bank, document, portal, etc.
  sourceReference String?  @map("source_reference")
  legalBasis      String   @map("legal_basis")
  
  // Permissions
  allowedUses     String[] @map("allowed_uses")
  prohibitedUses  String[] @map("prohibited_uses")
  
  // Quality
  confidenceScore Int?     @map("confidence_score")
  
  // Visibility
  visibilityRoles String[] @map("visibility_roles")
  
  // Lifecycle
  status          PassportStatus @default(ACTIVE)
  capturedAt      DateTime @default(now()) @map("captured_at")
  lastValidatedAt DateTime? @map("last_validated_at")
  expirationDate  DateTime? @map("expiration_date")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@map("data_passports")
}

model DataRestriction {
  id          String   @id @default(uuid()) @db.Uuid
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id") @db.Uuid
  fieldName   String   @map("field_name")
  restrictionType String @map("restriction_type")
  reason      String?
  appliedBy   String   @map("applied_by") @db.Uuid
  appliedAt   DateTime @default(now()) @map("applied_at")
  expiresAt   DateTime? @map("expires_at")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("data_restrictions")
}

// =========================
// ENUMS
// =========================

enum InstitutionType {
  BANK
  FUND
  COOPERATIVE
  FINANCIAL
  OTHER
}

enum EntityStatus {
  ACTIVE
  RESTRICTED
  BLOCKED
  SUSPENDED
}

enum PortfolioType {
  ASSIGNED
  CEDED
  PURCHASED
  MANDATE
  JUDICIAL
}

enum PortfolioStatus {
  ACTIVE
  PROCESSING
  CLOSED
  ARCHIVED
}

enum CaseStatus {
  ACTIVE
  RESTRICTED
  BLOCKED
  DISPUTED
  CLOSED
  JUDICIAL
}

enum ContactChannel {
  PHONE
  EMAIL
  WHATSAPP
  ADDRESS
}

enum ConsentType {
  COMMUNICATION
  DATA_PROCESSING
  WHATSAPP
  SMS
  EMAIL
}

enum CommChannel {
  EMAIL
  SMS
  PHONE
  WHATSAPP
  PORTAL
  LETTER
  VOICEBOT
}

enum CommDirection {
  INBOUND
  OUTBOUND
}

enum CommStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  BLOCKED
}

enum AgreementType {
  SETTLEMENT
  INSTALLMENTS
  FULL_PAYMENT
  DISCOUNT
}

enum AgreementStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
}

enum PromiseStatus {
  PENDING
  FULFILLED
  BROKEN
  EXTENDED
}

enum PaymentMethod {
  CARD
  TRANSFER
  DEPOSIT
  CASH
  GATEWAY
  OTHER
}

enum PaymentStatus {
  PENDING
  VERIFIED
  RECONCILED
  REJECTED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
  ESCALATED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  GESTOR
  ABOGADO
  COMPLIANCE
  BANCO
  DEUDOR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  DOWNLOAD
  CONTACT
  EXPORT
  LOGIN
  LOGOUT
  APPROVE
  REJECT
}

enum PassportStatus {
  ACTIVE
  RESTRICTED
  BLOCKED
  EXPIRED
  PENDING
}
