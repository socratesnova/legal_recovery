# Legal Recovery OS - Environment Variables Template
# Copy this file to .env (root) and/or apps/api/.env.local, then fill in real values.
# NEVER commit .env files with real secrets.

# =========================
# Database
# =========================
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# =========================
# Redis
# =========================
REDIS_URL=redis://HOST:6379

# =========================
# Keycloak (planned integration)
# =========================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=legal-recovery
KEYCLOAK_CLIENT_ID=legal-recovery-api
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# =========================
# JWT
# =========================
# Must be a strong, random secret of at least 32 bytes. No fallback is allowed in code.
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# =========================
# MinIO / S3
# =========================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=legal-recovery
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
# Max size for document uploads (bytes). Defaults to 50 MB.
UPLOAD_MAX_BYTES=52428800

# =========================
# Application
# =========================
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# =========================
# Frontend
# =========================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=legal-recovery
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=legal-recovery-web

# =========================
# AI Service (Phase 2)
# =========================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=CHANGE_ME

# =========================
# Communication Providers
# =========================
# When a provider is not configured, the NotificationDispatcher runs in
# SIMULATED mode: the communication is recorded with status=SENT and
# simulated=true, but no real message leaves the system. This lets the full
# contact flow work end-to-end in dev without any external service.
# Email (nodemailer / SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@legal-recovery.local

# SMS & WhatsApp via Twilio REST API (no SDK coupling)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+10000000000
TWILIO_WHATSAPP_FROM=+10000000000

# WhatsApp (restricted use only — requires explicit debtor opt-in, enforced
# by the Legal Firewall before any dispatch is attempted).
WHATSAPP_ENABLED=false

# =========================
# Security
# =========================
# Must be exactly 32 characters for AES-256-GCM.
ENCRYPTION_KEY=CHANGE_ME_TO_EXACTLY_32_CHAR_KEY_
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# =========================
# Observability
# =========================
LOG_LEVEL=info
ENABLE_AUDIT_LOG=true
METRICS_ENABLED=true
