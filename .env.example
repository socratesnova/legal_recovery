# Legal Recovery OS - Environment Variables
# Copy this file to .env and fill in the values

# =========================
# Database
# =========================
DATABASE_URL=postgresql://legal_recovery:legal_recovery_dev_2024@localhost:5432/legal_recovery?schema=public

# =========================
# Redis
# =========================
REDIS_URL=redis://localhost:6379

# =========================
# Keycloak
# =========================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=legal-recovery
KEYCLOAK_CLIENT_ID=legal-recovery-api
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# =========================
# JWT
# =========================
JWT_SECRET=legal-recovery-jwt-secret-2026-change-in-production
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# =========================
# MinIO / S3
# =========================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=legal-recovery
MINIO_USE_SSL=false

# =========================
# Application
# =========================
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# =========================
# Frontend
# =========================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=legal-recovery
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=legal-recovery-web

# =========================
# AI Service (Phase 2)
# =========================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=change-me

# =========================
# Communication Providers (Phase 2)
# =========================
# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS
SMS_PROVIDER=
SMS_API_KEY=

# WhatsApp (restricted use only)
WHATSAPP_ENABLED=false
WHATSAPP_API_KEY=

# =========================
# Security
# =========================
ENCRYPTION_KEY=change-me-32-char-key-for-production
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# =========================
# Observability
# =========================
LOG_LEVEL=info
ENABLE_AUDIT_LOG=true
METRICS_ENABLED=true
